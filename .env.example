# ===== SmartCurator 환경 변수 =====
# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요.
# cp .env.example .env  (Windows: copy .env.example .env)

# --- App ---
ENV=development
DEBUG=True

# --- CORS (JSON 배열 또는 쉼표 구분) ---
# 로컬 개발 + Vercel 프론트엔드 도메인 포함
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
# Vercel 프리뷰 도메인까지 허용하려면 아래 주석 해제
# ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/smartcurator
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smartcurator

# --- Security ---
# python -c "import secrets; print(secrets.token_urlsafe(64))" 로 생성
SECRET_KEY=replace-me

# --- OpenAI ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-3.5-turbo

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Qdrant ---
# 로컬 Docker (기본)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Qdrant Cloud 사용 시 아래로 대체
# QDRANT_URL=https://your-cluster.qdrant.tech
# QDRANT_API_KEY=replace-me
